{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "baseUrl": "./",
    "paths": {
      "*": ["./tests/*"]
    },
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "tests",
    "pages",
    "utils",
    "data",
    "./.eslintrc.js",
    "./playwright.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
